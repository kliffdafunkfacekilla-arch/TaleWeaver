import streamlit as st
import os
import re
import json
import sqlite3

# 1. SETUP
st.set_page_config(page_title="Ostraka Architect", layout="wide")
st.title("⚙️ The World Architect: Ostraka")

# DATABASE HELPER FUNCTIONS
def init_lore_db(db_name="state/shatterlands.db"):
    """Initializes the lore table in the engine's database with parameter support."""
    os.makedirs(os.path.dirname(db_name), exist_ok=True)
    conn = sqlite3.connect(db_name)
    cursor = conn.cursor()
    
    # Check if table exists
    cursor.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='lore_entries'")
    if not cursor.fetchone():
        cursor.execute('''
            CREATE TABLE lore_entries (
                title TEXT PRIMARY KEY,
                category TEXT,
                content TEXT,
                parameters TEXT
            )
        ''')
    else:
        # Migration: Check if parameters column exists
        cursor.execute("PRAGMA table_info(lore_entries)")
        columns = [column[1] for column in cursor.fetchall()]
        if 'parameters' not in columns:
            cursor.execute("ALTER TABLE lore_entries ADD COLUMN parameters TEXT")
            
    conn.commit()
    conn.close()

def load_all_lore_parameters(db_name="state/shatterlands.db"):
    """Reloads existing parameters from DB to preserve manual tuning during sync."""
    if not os.path.exists(db_name): return {}
    try:
        conn = sqlite3.connect(db_name)
        cursor = conn.cursor()
        cursor.execute("SELECT title, parameters FROM lore_entries")
        data = {row[0]: json.loads(row[1]) if row[1] else {} for row in cursor.fetchall()}
        conn.close()
        return data
    except:
        return {}

def save_single_entry(title, category, content, parameters, db_name="state/shatterlands.db"):
    """Saves or updates a single lore entry with its mechanical parameters."""
    conn = sqlite3.connect(db_name)
    cursor = conn.cursor()
    params_json = json.dumps(parameters)
    cursor.execute('''
        INSERT INTO lore_entries (title, category, content, parameters)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(title) DO UPDATE SET 
            category=excluded.category, 
            content=excluded.content,
            parameters=excluded.parameters
    ''', (title, category, content, params_json))
    conn.commit()
    conn.close()

# 2. THE HARVESTER LOGIC (Folder-Based + Persistence Merge)
def parse_obsidian_vault(vault_path):
    """Recursively walks the vault and merges existing DB parameters with fresh Obsidian content."""
    harvested_data = []
    
    if not os.path.exists(vault_path):
        st.sidebar.error(f"Path not found: {vault_path}")
        return []
        
    # Load existing tuning from DB
    existing_params = load_all_lore_parameters()
    
    for root, dirs, files in os.walk(vault_path):
        folder_name = os.path.basename(root).lower()
        
        for file in files:
            if file.endswith(".md"):
                file_path = os.path.join(root, file)
                title = file[:-3]
                
                try:
                    with open(file_path, "r", encoding="utf-8") as f:
                        raw_lore = f.read()
                    
                    category = "Uncategorized"
                    if "faction" in folder_name: category = "Factions (Empires)"
                    elif "culture" in folder_name: category = "Cultures (NPCs & Enemies)"
                    elif "resource" in folder_name: category = "Resources (Economy)"
                    elif "fauna" in folder_name or "flora" in folder_name: category = "Ecosystem (Flora & Fauna)"
                    elif "location" in folder_name: category = "Locations"
                    elif "tech" in folder_name: category = "Tech & Items"
                    elif any(kw in folder_name for kw in ["magic", "chaos", "people", "history"]): category = "Lore & Cosmology"
                    
                    harvested_data.append({
                        "title": title,
                        "category": category,
                        "lore": raw_lore,
                        "parameters": existing_params.get(title, {})
                    })
                except Exception as e:
                    st.error(f"Could not parse {file}: {e}")
                    
    return harvested_data

# 3. THE STREAMLIT UI (Sidebar & Ingestion)
init_lore_db() # Ensure DB exists on startup

vault_path = st.sidebar.text_input("Obsidian Vault Path", "./Shatterlands")

if st.sidebar.button("Sync with Obsidian"):
    with st.spinner("Harvesting Lore..."):
        data = parse_obsidian_vault(vault_path)
        if data:
            st.session_state['harvested_data'] = data
            st.sidebar.success(f"Vault Ingested! Integrated findings with existing DB parameters.")
        else:
            st.sidebar.warning("No files found or path invalid.")

# Sidebar Export (Global)
st.sidebar.markdown("---")
st.sidebar.subheader("Global Control")
if st.sidebar.button("Full Database Rebuild"):
    if 'harvested_data' in st.session_state and st.session_state['harvested_data']:
        try:
            for item in st.session_state['harvested_data']:
                save_single_entry(item['title'], item['category'], item['lore'], item.get('parameters', {}))
            st.sidebar.success("Global database rebuild complete!")
        except Exception as e:
            st.sidebar.error(f"Database error: {e}")
    else:
        st.sidebar.error("No data loaded.")

# 4. DISPLAYING THE DATA (Categorized Tabs)
if 'harvested_data' in st.session_state:
    data_list = st.session_state['harvested_data']
    tab_list = ["Factions (Empires)", "Cultures (NPCs & Enemies)", "Resources (Economy)", "Ecosystem (Flora & Fauna)", "Locations", "Tech & Items", "Lore & Cosmology", "Uncategorized"]
    tabs = st.tabs(tab_list)
    
    categorized_data = {tab_name: [] for tab_name in tab_list}
    for item in data_list:
        cat = item['category']
        if cat in categorized_data: categorized_data[cat].append(item)
        else: categorized_data["Uncategorized"].append(item)

    # Render loop
    for i, tab_name in enumerate(tab_list):
        with tabs[i]:
            items = categorized_data[tab_name]
            if not items:
                st.info(f"No files discovered in folder: {tab_name}")
            else:
                for item in items:
                    st.subheader(item['title'])
                    
                    # MODULE 1: Lore View
                    with st.expander("📖 View Source Data"):
                        st.write(item['lore'])
                    
                    # MODULE 2: THE PARAMETER TUNER
                    with st.expander("🛠️ The Parameter Tuner", expanded=False):
                        st.info(f"Tuning mechanical hooks for: {item['title']} ({item['category']})")
                        
                        g_stats = item.get("parameters", {})
                        
                        # CATEGORY SPECIFIC FORMS
                        if tab_name == "Factions (Empires)":
                            trade_opts = ["Never", "Friends Only (If friendly needs it)", "Excess (Will sell extras)", "Priority (Trade anything to anyone)"]
                            agg_opts = ["Passive (Defend/Negotiate only)", "Defensive (Defend/Counter-attack/Negotiate)", "Need (Negotiate first, War if needed)", "Bully (Force over talks, take what it wants)", "Bloodthirsty (Immediate force against anyone)"]
                            
                            g_stats['trade_policy'] = st.selectbox("Trade Policy", trade_opts, index=trade_opts.index(g_stats.get('trade_policy', trade_opts[0])) if g_stats.get('trade_policy') in trade_opts else 0, key=f"{item['title']}_trade")
                            g_stats['aggression_policy'] = st.selectbox("Aggression Policy", agg_opts, index=agg_opts.index(g_stats.get('aggression_policy', agg_opts[1])) if g_stats.get('aggression_policy') in agg_opts else 1, key=f"{item['title']}_agg")
                            
                            c1, c2, c3 = st.columns(3)
                            g_stats['wealth'] = c1.slider("Starting Wealth", 1, 100, g_stats.get('wealth', 50), key=f"{item['title']}_wealth")
                            g_stats['drive'] = c2.slider("Starting Drive", 1, 100, g_stats.get('drive', 50), key=f"{item['title']}_drive")
                            g_stats['tech_level'] = c3.slider("Starting Tech Level", 1, 100, g_stats.get('tech_level', 10), key=f"{item['title']}_tech")
                            
                        elif tab_name == "Cultures (NPCs & Enemies)":
                            disp_opts = ["Friendly NPC", "Hostile Enemy"]
                            var_opts = ["Body-Variant (Physical Focus)", "Mind-Variant (Mental Focus)"]
                            
                            c1, c2 = st.columns(2)
                            g_stats['disposition'] = c1.selectbox("Entity Disposition", disp_opts, index=disp_opts.index(g_stats.get('disposition', disp_opts[0])) if g_stats.get('disposition') in disp_opts else 0, key=f"{item['title']}_disp")
                            g_stats['variant'] = c2.selectbox("Biological Variant", var_opts, index=var_opts.index(g_stats.get('variant', var_opts[0])) if g_stats.get('variant') in var_opts else 0, key=f"{item['title']}_var")
                            
                            c1, c2 = st.columns(2)
                            g_stats['threat'] = c1.number_input("Threat Level / Tier", 1, 5, g_stats.get('threat', 1), key=f"{item['title']}_threat")
                            g_stats['skill'] = c2.text_input("Signature Skill / Tactic", g_stats.get('skill', "Basic Strike"), key=f"{item['title']}_skill")
                            
                            g_stats['tags'] = st.text_input("Mechanic Tags (Comma separated)", g_stats.get('tags', "flesh, organic"), key=f"{item['title']}_tags")
                            
                            c1, c2, c3, c4 = st.columns(4)
                            g_stats['hp'] = c1.number_input("Base HP", 0, 500, g_stats.get('hp', 20), key=f"{item['title']}_hp")
                            g_stats['composure'] = c2.number_input("Base Composure", 0, 500, g_stats.get('composure', 15), key=f"{item['title']}_comp")
                            g_stats['stamina'] = c3.number_input("S-Die (Stamina)", 1, 20, g_stats.get('stamina', 10), key=f"{item['title']}_stam")
                            g_stats['focus'] = c4.number_input("F-Die (Focus)", 1, 20, g_stats.get('focus', 10), key=f"{item['title']}_focus")

                        elif tab_name == "Ecosystem (Flora & Fauna)":
                            repr_opts = ["Very Slow", "Slow", "Moderate", "Fast", "Invasive"]
                            biome_opts = ["Dust Bowl", "Tangle/Jungle", "High Peaks", "Swamp/Mire", "Deep Subterranean", "Coastal/Oceanic"]
                            harv_opts = ["Requires Killing (e.g., Hide/Meat)", "Harvested Alive (e.g., Milk/Shed/Fruit)", "Not Harvestable"]
                            
                            g_stats['reproduction'] = st.select_slider("Reproduction / Multiplication Rate", options=repr_opts, value=g_stats.get('reproduction', "Moderate"), key=f"{item['title']}_repr")
                            g_stats['biomes'] = st.multiselect("Preferred Biomes/Climate", biome_opts, default=g_stats.get('biomes', []), key=f"{item['title']}_biomes")
                            
                            c1, c2 = st.columns(2)
                            g_stats['is_hostile'] = c1.checkbox("Is Hostile / Dangerous?", g_stats.get('is_hostile', False), key=f"{item['title']}_hostile")
                            g_stats['is_tameable'] = c2.checkbox("Is Tameable / Farmable?", g_stats.get('is_tameable', False), key=f"{item['title']}_tame")
                            
                            g_stats['aggression'] = st.slider("Spread Aggression (How fast it overtakes new locales)", 1, 10, g_stats.get('aggression', 3), key=f"{item['title']}_spread")
                            g_stats['harvest'] = st.selectbox("Harvest Method", harv_opts, index=harv_opts.index(g_stats.get('harvest', harv_opts[2])) if g_stats.get('harvest') in harv_opts else 2, key=f"{item['title']}_harv")
                            g_stats['skill'] = st.text_input("Beast Skill / Tactic", g_stats.get('skill', "Bite"), key=f"{item['title']}_bskill")
                            g_stats['statblock'] = st.text_area("Base Statblock (JSON or Text)", g_stats.get('statblock', ""), key=f"{item['title']}_stats")

                        elif tab_name == "Tech & Items":
                            tag_opts = ["Weapon", "Armor", "Consumable", "Quest/Misc"]
                            g_stats['item_tag'] = st.selectbox("Item Tag", tag_opts, index=tag_opts.index(g_stats.get('item_tag', tag_opts[0])) if g_stats.get('item_tag') in tag_opts else 0, key=f"{item['title']}_itag")
                            g_stats['base_item'] = st.text_input("Tied Base Item (e.g., Heavy Sword, Plate Mail)", g_stats.get('base_item', ""), key=f"{item['title']}_base")
                            
                            c1, c2 = st.columns(2)
                            g_stats['effect_val'] = c1.number_input("Effect Value (Damage or Armor rating)", 0, 50, g_stats.get('effect_val', 0), key=f"{item['title']}_eval")
                            g_stats['loadout'] = c2.number_input("Loadout Number (Capacity Tax)", 0, 5, g_stats.get('loadout', 1), key=f"{item['title']}_load")
                            
                            g_stats['effects'] = st.text_area("Other Mechanical Effects (e.g., Applies [Burn], Restores 2 S-Die)", g_stats.get('effects', ""), key=f"{item['title']}_effects")
                        
                        else:
                            g_stats['custom_params'] = st.text_area("Dynamic Parameters (JSON/Text)", g_stats.get('custom_params', ""), key=f"{item['title']}_custom")

                        # THE SAVE BUTTON
                        if st.button(f"Save '{item['title']}' Parameters", key=f"{item['title']}_save"):
                            save_single_entry(item['title'], item['category'], item['lore'], g_stats)
                            st.success(f"Parameters for {item['title']} written to DB!")
                            # Update session state memory
                            item['parameters'] = g_stats

                    st.divider()
else:
    st.info("👈 Sync with Obsidian to see your folder-organized lore.")
