import db_manager
import json
import random
import pygame

# Mapping between Cartographer labels and world_regions.json IDs
BIOME_MAPPING = {
    "Ocean": "ocean_shelf", "Dust Bowl": "dust_bowl_wastes",
    "Grind-Canyons": "the_grind", "Verdant Tangle": "pine_forest",
    "High Peaks": "frostpeak_tundra", "Swamp-Mire": "blackwood_swamp",
    "Forest": "pine_forest"
}

def load_json(filepath):
    try:
        with open(filepath, "r", encoding="utf-8-sig") as f: return json.load(f)
    except: return {}

class MapGenerator:
    def __init__(self, cell_size=40, grid_width=20, grid_height=15, log_width=350):
        self.cell_size = cell_size
        self.grid_width = grid_width
        self.grid_height = grid_height
        self.log_width = log_width

    def draw_grid(self, screen, colors, ui_height):
        """Renders the standard tactical grid lines."""
        map_pixel_width = self.grid_width * self.cell_size
        map_pixel_height = self.grid_height * self.cell_size
        for x in range(0, map_pixel_width + 1, self.cell_size):
            pygame.draw.line(screen, colors["grid"], (x, 0), (x, map_pixel_height))
        for y in range(0, map_pixel_height + 1, self.cell_size):
            pygame.draw.line(screen, colors["grid"], (0, y), (map_pixel_width, y))

    def draw_entities(self, screen, map_data, cam_x, cam_y, colors, icon_font):
        """Renders all entities in the current camera view."""
        for entity in map_data.get("entities", []):
            grid_x, grid_y = entity["pos"][0] - cam_x, entity["pos"][1] - cam_y
            if 0 <= grid_x < self.grid_width and 0 <= grid_y < self.grid_height:
                pixel_x, pixel_y = grid_x * self.cell_size, grid_y * self.cell_size
                tags = entity.get("tags", [])
                ent_type = entity.get("type", "prop")
                
                # Dynamic Coloring
                color = colors.get(ent_type, (150, 150, 150))
                if "water" in tags: color = colors["water"]
                elif "plant" in tags: color = colors["plant"]
                elif "wall" in tags: color = colors["wall"]
                if "dead" in tags: color = colors["dead"]
                
                pygame.draw.rect(screen, color, (pixel_x + 2, pixel_y + 2, self.cell_size - 4, self.cell_size - 4))
                
                # Icon Overlay
                if ent_type != "terrain" and "dead" not in tags:
                    initial = "@" if ent_type == "player" else entity["name"][0].upper()
                    text_surf = icon_font.render(initial, True, (255, 255, 255))
                    screen.blit(text_surf, text_surf.get_rect(center=(pixel_x + self.cell_size // 2, pixel_y + self.cell_size // 2)))

def generate_local_map(global_pos=[0,0], local_pos=[50,50], player_data=None, quest_deck=None):
    """
    PLANETARY ZOOM: Handles the 10x10 -> 100x100 -> 100x100 hierarchy.
    """
    absolute_x = (global_pos[0] * 100) + local_pos[0]
    absolute_y = (global_pos[1] * 100) + local_pos[1]

    l4_x, remain_l4_x = divmod(absolute_x, 10000)
    l4_y, remain_l4_y = divmod(absolute_y, 10000)
    
    grid_w, grid_h = 100, 100
    world_data = load_json("data/world_regions.json")
    
    macro_cell = db_manager.get_macro_cell(l4_x, l4_y)
    master_seed = (absolute_x * 342) + (absolute_y * 123)
    random.seed(master_seed)
    
    biome_key = "pine_forest"
    if macro_cell:
        biome_key = BIOME_MAPPING.get(macro_cell["biome"], "pine_forest")
    
    region = world_data.get("regions", {}).get(biome_key, world_data.get("regions", {}).get("pine_forest", {}))
    
    local_map_data = {
        "entities": [],
        "meta": {
            "grid_size": [grid_w, grid_h],
            "global_pos": global_pos,
            "region_id": biome_key,
            "clock": 0,
            "campaign_tracker": {
                "main_plot": "Hunting the bandits who burned your village.",
                "active_subplot": None,
                "quest_history": [],
                "active_quest_deck": quest_deck if quest_deck else []
            }
        }
    }
    
    if not player_data:
        player_data = {
            "name": "Jax", "type": "player", "pos": local_pos,
            "hp": 20, "max_hp": 20,
            "resources": {"stamina": 10, "max_stamina": 10, "focus": 10, "max_focus": 10},
            "inventory": ["Bandage"], "skills": ["Slash"], "tags": ["unbreakable"]
        }
    else:
        player_data["pos"] = local_pos
        
    local_map_data["entities"].append(player_data)
    
    # Corrected Spawning Logic
    spawn_pool = region.get("flora", []) + region.get("fauna", []) + region.get("factions", [])
    
    if spawn_pool:
        num_spawns = random.randint(40, 60)
        for _ in range(num_spawns):
            s_name = random.choice(spawn_pool)
            pos = [random.randint(2, grid_w-3), random.randint(2, grid_h-3)]
            if pos != local_pos:
                ent_type = "npc"
                if s_name in region.get("flora", []): ent_type = "prop"
                if s_name in region.get("factions", []): ent_type = "hostile"
                
                local_map_data["entities"].append({
                    "name": s_name, "type": ent_type, "pos": pos, 
                    "hp": 5, "tags": ["living", "biome_spawn"]
                })

    return local_map_data

def generate_interior_room(current_room):
    grid_w, grid_h = 12, 12
    return {"entities": [], "meta": {"grid_size": [grid_w, grid_h], "region_id": "interior", "clock": 0}}
