import pygame
import threading
import json
import os
import time
import sys
from queue import Queue

# Core Ostraka Pipeline Imports
import actions
import engine
import narrator
import map_generator

# Configuration & Constants
CELL_SIZE = 40
GRID_W, GRID_H = 20, 15
TOTAL_W = GRID_W * CELL_SIZE
TOTAL_H = GRID_H * CELL_SIZE
SIDEBAR_W = 350
WINDOW_W = TOTAL_W + SIDEBAR_W
WINDOW_H = TOTAL_H

COLORS = {
    "bg": (15, 15, 20),
    "grid": (40, 40, 45),
    "player": (100, 200, 255),
    "hostile": (255, 80, 80),
    "npc": (200, 255, 100),
    "prop": (180, 180, 160),
    "text": (220, 220, 220),
    "title": (255, 215, 0),
    "dead": (60, 60, 65)
}

class OstrakaGame:
    def __init__(self):
        """Initializes the Dual-State Ostraka Engine."""
        pygame.init()
        self.screen = pygame.display.set_mode((WINDOW_W, WINDOW_H))
        pygame.display.set_caption("OSTRAKA: SHATTERLANDS VTT")
        self.clock = pygame.time.Clock()
        
        # 1. Pipeline Handlers
        self.parser = actions.IntentResolver()
        self.game_physicist = engine.GameEngine()
        self.storyteller = narrator.Narrator()
        
        # 2. Map Rendering
        self.map_renderer = map_generator.MapGenerator(CELL_SIZE, GRID_W, GRID_H, SIDEBAR_W)
        self.font = pygame.font.SysFont("Consolas", 16)
        self.title_font = pygame.font.SysFont("Consolas", 24, bold=True)
        
        # 3. Game State
        self.state = engine.load_state()
        self.game_state = "EXPLORATION"
        self.input_queue = Queue()
        
        # Find Jax correctly
        player = self._get_player()
        if player:
            self.current_x, self.current_y = player["pos"]
        else:
            self.current_x, self.current_y = 55, 55 # Fallback
            
        self.running = True

    def _get_player(self):
        return next((e for e in self.state["local_map_state"].get("entities", []) if e.get("type") == "player"), None)

    def _get_world_context(self):
        """Reads active campaign data for AI immersion."""
        try:
            with open("data/Saves/campaign_active.json", "r") as f:
                camp = json.load(f)
            node = camp["nodes"][camp["current_node_index"]]
            return f"Goal: {camp['locked_goal']}. Objective: {node.get('task')}"
        except:
            return "You are exploring the Shatterlands, seeking the Iron Caldera blueprints."

    def _terminal_listener(self):
        """Background thread to capture non-blocking terminal input."""
        print("\n[TERMINAL LINK ACTIVE] >>> Type your actions here.")
        while self.running:
            try:
                user_text = input("\n[ACTION]> ")
                if user_text:
                    self.input_queue.put(user_text)
            except EOFError:
                break

    def _handle_pipeline_turn(self, player_text):
        """Orchestrates the 3-step semantic turn resolution."""
        ctx = self._get_world_context()
        player = self._get_player()
        
        print("\n- Parsing intent...")
        intent = self.parser.parse_player_input(player_text, ctx)
        
        print("- Resolving physics...")
        res = self.game_physicist.execute_action(intent, player, self.state)
        
        # Update local diorama coords if move succeeded
        if res["status"] == "SUCCESS":
            self.current_x, self.current_y = player["pos"]
        
        print("- The DM is typing...")
        story = self.storyteller.narrate_turn_result(res, ctx)
        
        print(f"\n{'-'*50}\n{story}\n{'-'*50}")
        
        # Save real world state
        engine.save_state(self.state)

    def start_game(self):
        """Primary Engine Loop: Keeps Pygame alive while checking terminal queue."""
        # Start Input Thread
        t = threading.Thread(target=self._terminal_listener, daemon=True)
        t.start()
        
        while self.running:
            # 1. PUMP EVENTS (Keep window responsive)
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    self.running = False
            
            # 2. CHECK QUEUE (Player Actions)
            if not self.input_queue.empty():
                player_text = self.input_queue.get()
                if player_text.lower() in ['exit', 'quit']:
                    self.running = False
                else:
                    self._handle_pipeline_turn(player_text)

            # Sync Mode with Engine
            is_combat = self.state["local_map_state"].get("meta", {}).get("in_combat", False)
            self.game_state = "COMBAT" if is_combat else "EXPLORATION"

            # 3. RENDER VISUALS
            self.screen.fill(COLORS["bg"])
            
            # Camera centering logic
            cam_x = self.current_x - (GRID_W // 2)
            cam_y = self.current_y - (GRID_H // 2)
            
            self.map_renderer.draw_grid(self.screen, COLORS, WINDOW_H)
            self.map_renderer.draw_entities(self.screen, self.state["local_map_state"], cam_x, cam_y, COLORS, self.title_font)
            
            # Sidebar / Status Panel
            p_data = self._get_player()
            if p_data:
                y = 20
                self.screen.blit(self.title_font.render(f"NAME: {p_data['name']}", True, COLORS["title"]), (TOTAL_W + 20, y)); y+=30
                self.screen.blit(self.font.render(f"HP: {p_data['hp']}/{p_data.get('max_hp', 20)}", True, COLORS["hostile"]), (TOTAL_W + 20, y)); y+=25
                self.screen.blit(self.font.render(f"POS: {self.current_x}, {self.current_y}", True, COLORS["player"]), (TOTAL_W + 20, y)); y+=25
                self.screen.blit(self.font.render(f"MODE: {self.game_state}", True, (200, 200, 200)), (TOTAL_W + 20, y))

            pygame.display.flip()
            self.clock.tick(30)

        pygame.quit()
        print("\nDirector: Simulation terminated. Data persisted to local_map_state.json")

if __name__ == "__main__":
    game = OstrakaGame()
    game.start_game()
